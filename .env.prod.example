# PostgreSQL (used by docker-compose.prod.yml and the web container)
POSTGRES_USER=duca
# Generate: openssl rand -hex 16
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=duca_ctf

# App secrets
# Generate: openssl rand -base64 36   (must be at least 32 characters)
SESSION_SECRET=change-me-to-a-random-32-character-string
SESSION_COOKIE_SECURE=true

# SMTP (required for login codes)
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_USER=services@example.com
SMTP_PASS=
SMTP_FROM_EMAIL=services@example.com

# DATABASE_URL and REDIS_URL are set automatically in docker-compose.prod.yml.
# Only override here if you run the web container outside Compose.

# Database backups (optional)
# BACKUP_KEEP_COUNT=3

# Activity log retention (optional)
# ACTIVITY_LOG_RETENTION_DAYS=14

# Error tracking (Bugsink — required at image build time for browser errors)
# BUGSINK_DSN=https://<key>@bugsink.example.com/<project-id>
